        "message": "=<!DOCTYPE html><html><body style='font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px'><h2 style='color:#1a56db'>ScrapFlow SA — Payment Receipt</h2><table width='100%' style='border-collapse:collapse;margin-bottom:20px'><tr style='background:#f3f4f6'><td style='padding:8px 12px;font-weight:bold'>Ticket Number</td><td style='padding:8px 12px'>{{ $json.data.ticketNumber }}</td></tr><tr><td style='padding:8px 12px;font-weight:bold'>Site</td><td style='padding:8px 12px'>{{ $json.data.siteName }}</td></tr><tr style='background:#f3f4f6'><td style='padding:8px 12px;font-weight:bold'>Supplier</td><td style='padding:8px 12px'>{{ $json.data.supplier.fullName }}</td></tr><tr><td style='padding:8px 12px;font-weight:bold'>Contact</td><td style='padding:8px 12px'>{{ $json.data.supplier.contactNumber }}</td></tr><tr style='background:#f3f4f6'><td style='padding:8px 12px;font-weight:bold'>EFT Reference</td><td style='padding:8px 12px'>{{ $json.data.paymentReference }}</td></tr><tr><td style='padding:8px 12px;font-weight:bold'>Net Weight</td><td style='padding:8px 12px'>{{ $json.data.netWeight }} kg</td></tr><tr style='background:#f3f4f6'><td style='padding:8px 12px;font-weight:bold'>Total Payment</td><td style='padding:8px 12px;font-size:18px;font-weight:bold;color:#059669'>R {{ $json.data.totalPrice }}</td></tr></table><h3>Materials Purchased</h3><table width='100%' style='border-collapse:collapse'><thead><tr style='background:#1a56db;color:white'><th style='padding:8px 12px;text-align:left'>Material</th><th style='padding:8px 12px;text-align:right'>Net Weight (kg)</th><th style='padding:8px 12px;text-align:right'>Line Total (R)</th></tr></thead><tbody>{{ $json.data.lineItems.map((li, i) => `<tr style='background:${i%2===0?'#f9fafb':'white'}'><td style='padding:8px 12px'>${li.materialCode}</td><td style='padding:8px 12px;text-align:right'>${li.netWeight}</td><td style='padding:8px 12px;text-align:right'>${li.lineTotal}</td></tr>`).join('') }}</tbody></table><br/><p style='color:#6b7280;font-size:12px'>This is an automated receipt from ScrapFlow SA. All payments are processed via EFT in compliance with the Second-Hand Goods Act.</p></body></html>",
